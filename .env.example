# ═══════════════════════════════════════════════════════════
# Docker — მხოლოდ ეს ცვლადები იცვლება პროექტიდან პროექტამდე
# ═══════════════════════════════════════════════════════════

DOCKER_PHP_VERSION=8.2
DOCKER_HTTP_PORT=8080

# ── Database engine: mysql ან postgres ──────────────────────
#
# MySQL:
DOCKER_DB_IMAGE=mysql
DOCKER_DB_VERSION=8.0
DOCKER_DB_PORT=3307
DOCKER_DB_INTERNAL_PORT=3306
DOCKER_DB_HEALTHCHECK=mysqladmin ping -h localhost
#
# PostgreSQL (ზემოთს ჩაანაცვლე ამით):
# DOCKER_DB_IMAGE=postgres
# DOCKER_DB_VERSION=16
# DOCKER_DB_PORT=5433
# DOCKER_DB_INTERNAL_PORT=5432
# DOCKER_DB_HEALTHCHECK=pg_isready -U laravel

# ═══════════════════════════════════════════════════════════
# Laravel Application
# ═══════════════════════════════════════════════════════════

APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ── Database ─────────────────────────────────────────────────
DB_CONNECTION=mysql        # postgres-ზე შეცვალე: pgsql
DB_HOST=db                 # ყოველთვის "db" (127.0.0.1 არა)
DB_PORT=3306               # postgres: 5432
DB_DATABASE=laravel
DB_USERNAME=laravel
DB_PASSWORD=secret
DB_ROOT_PASSWORD=root      # MySQL-ისთვის

CACHE_STORE=database
SESSION_DRIVER=database
SESSION_LIFETIME=120
QUEUE_CONNECTION=database

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
